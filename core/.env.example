# Core service environment. Copy to .env and fill in.

# Postgres connection string (Supabase).
# Use the session-mode pooler (port 5432) or the direct connection — NOT the
# transaction pooler (6543), which lacks the session features LISTEN/NOTIFY needs.
DATABASE_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres

# HTTP port the API listens on.
PORT=3000

# development | test | production
NODE_ENV=development
