# AI advisory service environment.

# Same Postgres the core uses (Supabase session pooler URL).
DATABASE_URL=postgresql://postgres.<ref>:password@aws-0-<region>.pooler.supabase.com:5432/postgres

# Optional: when set, advisories are written by Claude. Without it, a
# deterministic template generates them so the pipeline still runs.
# ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-opus-4-8

# How often the background loop analyzes failures (seconds).
ANALYZE_INTERVAL_SECONDS=300
ADVISORY_LOOKBACK_HOURS=24
AI_PORT=8000
