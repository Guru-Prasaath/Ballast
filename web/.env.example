# Web dashboard environment.
#
# By default the app runs against the MSW mock backend, so `npm run dev` works
# standalone with no variables set.
#
# To run against the real core API instead:
#   1. Start the core (cd ../core && npm run start:dev) on port 3000.
#   2. Set the flag below; Vite proxies /api/v1 → localhost:3000 in dev.
# VITE_USE_MOCKS=false
#
# In production (served from a different origin), also point at the API directly:
# VITE_API_URL=https://api.your-deploy.example/api/v1
